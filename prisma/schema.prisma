// مخطط قاعدة بيانات حاسبة بلوت
// المرجع: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// المستخدمون والصلاحيات
// ============================================================

enum UserRole {
  ADMIN // كل الصلاحيات
  SUPPORT // دعم فني — يساعد المستخدمين بحل المشاكل
  CONTENT_CREATOR // صانع محتوى — يدير إعلاناته الخاصة + اتجاه شاشته
  USER // مستخدم عادي
}

enum TVOrientation {
  LANDSCAPE // عرضي (افقي)
  PORTRAIT // طولي (عمودي)
}

enum CalculatorStyle {
  CLASSIC // الحاسبة الكلاسيكية (الافتراضية)
  ADVANCED // الحاسبة المتقدمة (تصميم مينمالي)
}

model User {
  id            String        @id @default(cuid())
  username      String        @unique
  passwordHash  String
  displayName   String
  role            UserRole        @default(USER)
  tvOrientation   TVOrientation   @default(LANDSCAPE)
  calculatorStyle CalculatorStyle @default(ADVANCED)
  tvCode          String?         @unique
  active        Boolean       @default(true)
  phone         String?       // رقم الجوال (اختياري — يُدخله المستخدم عند التسجيل)
  createdAt     DateTime      @default(now())
  lastLoginAt   DateTime?

  // استوديو شاشة التلفزيون - تخصيص صانع المحتوى
  tvAccentColor   String   @default("#f5b042") // اللون الذهبي افتراضياً
  tvShowRounds    Boolean  @default(true)
  tvShowChat      Boolean  @default(false)
  tvChatUrl       String? // رابط iframe لشات البث
  tvShowDonations Boolean  @default(false)
  tvDonationUrl   String? // رابط iframe للدونيشن
  tvLogoUrl       String? // لوغو شخصي اختياري (يحلّ محل "بلوت")
  tvShowAlert     Boolean  @default(false)
  tvAlertUrl      String? // رابط صندوق التنبيهات (Streamlabs / StreamElements)
  tvStreamlabsToken String? // Socket API Token من Streamlabs (للاتصال المباشر)
  tvAlertSound      String? // صوت مخصص للتنبيهات (مرفوع من الجهاز)
  tvRefreshSeconds  Int      @default(0) // 0 = مُطفأ (تحديث لحظي SSE) / >0 = تحديث إجباري بعدّاد تنازلي

  // اليوزر الفرعي — يشير إلى الحساب الأصل (صانع المحتوى)
  parentUserId String?
  parentUser   User?   @relation("SubUsers", fields: [parentUserId], references: [id], onDelete: SetNull)
  subUsers     User[]  @relation("SubUsers")

  // صلاحيات المستخدم الفرعي — يُحددها صانع المحتوى (فقط ذات معنى عند parentUserId != null)
  subCanStartGame   Boolean @default(true)
  subCanAddPlayers  Boolean @default(true)
  subCanViewHistory Boolean @default(true)
  subCanViewStats   Boolean @default(true)

  players Player[]
  games   Game[]
  banners AdBanner[]
  teams       Team[]
  tournaments Tournament[]

  @@index([role])
  @@index([parentUserId])
}

// ============================================================
// لاعبون يملكهم المستخدم (روستر شخصي)
// ============================================================

model Player {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String? // صورة اللاعب (مسار في public/uploads/players)
  userId    String
  createdAt DateTime @default(now())

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  participants GameParticipant[]
  teamsAsP1    Team[]            @relation("TeamPlayer1")
  teamsAsP2    Team[]            @relation("TeamPlayer2")

  @@unique([userId, name])
  @@index([userId])
}

// ============================================================
// المباريات
// ============================================================

enum GameStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

// نوع اللعب:
// NORMAL   = عادي (٠ → ١٥٢)
// MASHDOOD = مشدود (٥٢ → ١٥٢)
enum GameMode {
  NORMAL
  MASHDOOD
}

model Game {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ملاحظة: كود التلفزيون الآن دائم على المستخدم (User.tvCode)
  mode        GameMode   @default(NORMAL)
  status      GameStatus @default(IN_PROGRESS)
  team1Score  Int        @default(0) // "لنا"
  team2Score  Int        @default(0) // "لهم"
  winner      Int? // 1 أو 2 أو null
  targetScore Int        @default(152)

  startedAt DateTime  @default(now())
  endedAt   DateTime?

  // ربط الصكة بمواجهة بطولة (اختياري)
  matchId String?
  match   Match?  @relation(fields: [matchId], references: [id], onDelete: SetNull)

  participants GameParticipant[]
  rounds       Round[]

  @@index([userId, startedAt])
  @@index([userId, status])
  @@index([startedAt]) // للإحصائيات الشهرية
  @@index([matchId])
}

model GameParticipant {
  id       String @id @default(cuid())
  gameId   String
  playerId String
  team     Int // 1 أو 2

  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Restrict)

  @@unique([gameId, playerId])
  @@index([playerId])
}

model Round {
  id         String   @id @default(cuid())
  gameId     String
  number     Int
  team1Score Int
  team2Score Int
  createdAt  DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, number])
  @@index([gameId])
}

// ============================================================
// إعدادات التطبيق (سطر واحد فقط - singleton)
// ============================================================

model AppSetting {
  id Int @id @default(1) // دائماً 1، نضمن سطر واحد فقط

  // وضع الصيانة - يقفل التطبيق على الكل ما عدا الأدمن
  maintenanceMode    Boolean @default(false)
  maintenanceMessage String  @default("التطبيق تحت الصيانة، نرجع قريباً")

  // الإعدادات الافتراضية للمباريات
  defaultTargetScore Int @default(152)

  // معلومات تظهر للمستخدمين
  appName    String @default("بلوت")
  appTagline String @default("حاسبة بلوت احترافية")

  updatedAt DateTime @updatedAt
}

// ============================================================
// إعلانات الشريط السفلي
// ============================================================

model AdBanner {
  id        String   @id @default(cuid())
  text      String?
  imageUrl  String?
  linkUrl   String?
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // null = إعلان عام يديره الأدمن (يظهر للجميع)
  // userId = إعلان خاص بصانع المحتوى (يظهر فقط على مبارياته/تلفزيونه)
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([active, order])
  @@index([userId, active, order])
}

// ============================================================
// البطولات
// ============================================================

enum TournamentFormat {
  KNOCKOUT // خروج المغلوب
  POINTS   // تجميع النقاط (دوري كامل — الكل ضد الكل)
}

enum TournamentStatus {
  DRAFT       // إعداد — إضافة الفرق
  DRAWN       // تمت القرعة، الشجرة/الجدول جاهز
  IN_PROGRESS // قيد اللعب
  COMPLETED   // انتهت
}

enum MatchStatus {
  PENDING     // بانتظار تحديد الفريقين أو بدء الصكة
  IN_PROGRESS // صكة جارية
  COMPLETED   // حُسمت المواجهة
}

// فريق = زوج لاعبين من روستر المستخدم — خاص بالبطولة التي أُنشئ فيها
model Team {
  id        String   @id @default(cuid())
  userId    String
  name      String
  player1Id String
  player2Id String
  createdAt DateTime @default(now())

  // الفريق ملك بطولته — حذف البطولة يحذف فرقها
  tournamentId String?
  tournament   Tournament? @relation("TournamentOwnedTeams", fields: [tournamentId], references: [id], onDelete: Cascade)

  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  player1 Player @relation("TeamPlayer1", fields: [player1Id], references: [id], onDelete: Restrict)
  player2 Player @relation("TeamPlayer2", fields: [player2Id], references: [id], onDelete: Restrict)

  tournamentTeams TournamentTeam[]
  matchesAsA      Match[]          @relation("MatchTeamA")
  matchesAsB      Match[]          @relation("MatchTeamB")
  matchesWon      Match[]          @relation("MatchWinner")

  @@index([userId])
  @@index([tournamentId])
}

model Tournament {
  id          String           @id @default(cuid())
  userId      String
  name        String
  format      TournamentFormat
  matchBestOf Int              @default(1) // 1 = صكة واحدة / 3 = أفضل من ٣
  gameMode    GameMode         @default(NORMAL)
  status      TournamentStatus @default(DRAFT)
  championTeamId String?       // الفريق البطل عند الانتهاء
  createdAt   DateTime         @default(now())

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  teams      TournamentTeam[]
  ownedTeams Team[]           @relation("TournamentOwnedTeams")
  matches    Match[]

  @@index([userId])
}

// مشاركة فريق في بطولة + ترتيبه/إحصاءاته داخلها
model TournamentTeam {
  id           String    @id @default(cuid())
  tournamentId String
  teamId       String
  seed         Int       @default(0) // ترتيب القرعة
  points       Int       @default(0) // نظام تجميع النقاط
  wins         Int       @default(0) // مواجهات مكسوبة
  losses       Int       @default(0) // مواجهات مخسورة
  eliminated   Boolean   @default(false) // خروج المغلوب
  lastWinAt    DateTime? // آخر فوز — لكسر التعادل في الترتيب

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team       Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, teamId])
  @@index([tournamentId])
}

model Match {
  id           String      @id @default(cuid())
  tournamentId String
  round        Int         @default(1) // الدور (إقصاء) أو الجولة (دوري)
  position     Int         @default(0) // الموقع داخل الدور
  teamAId      String? // قد يكون null في الإقصاء حتى يتأهل فريق
  teamBId      String?
  teamAWins    Int         @default(0) // عدد الصكات الفائزة للفريق أ
  teamBWins    Int         @default(0) // عدد الصكات الفائزة للفريق ب
  bestOf       Int         @default(1)
  winnerTeamId String?
  status       MatchStatus @default(PENDING)
  decidedAt    DateTime? // وقت حسم المواجهة — لكسر التعادل في الترتيب

  // تقدّم شجرة الإقصاء: المواجهة التالية التي يصعد لها الفائز
  nextMatchId String?
  nextSlot    Int? // 1 = يدخل خانة الفريق أ / 2 = خانة الفريق ب
  nextMatch   Match?   @relation("BracketProgression", fields: [nextMatchId], references: [id], onDelete: SetNull)
  prevMatches Match[]  @relation("BracketProgression")

  createdAt DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamA      Team?      @relation("MatchTeamA", fields: [teamAId], references: [id], onDelete: SetNull)
  teamB      Team?      @relation("MatchTeamB", fields: [teamBId], references: [id], onDelete: SetNull)
  winnerTeam Team?      @relation("MatchWinner", fields: [winnerTeamId], references: [id], onDelete: SetNull)
  games      Game[]

  @@index([tournamentId, round])
}
